[CmdletBinding()]
param(
    [string]$Version,
    [string]$InstallDir,
    [string]$Repository,
    [string]$ReleaseBaseUrl,
    [switch]$NoModifyPath
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"
$Program = "__BINARY_NAME__"
$DisplayName = "__DISPLAY_NAME__"
$DefaultRepository = "__REPOSITORY__"
$EnvironmentPrefix = "__ENVIRONMENT_PREFIX__"

function Get-CliEnvironmentValue {
    param([Parameter(Mandatory = $true)][string]$Suffix)
    return [Environment]::GetEnvironmentVariable("$($EnvironmentPrefix)_$Suffix")
}

function Get-CliNormalizedVersion {
    param([Parameter(Mandatory = $true)][string]$Value)
    if ($Value -eq "latest") { return "latest" }
    if ($Value.StartsWith("v", [StringComparison]::OrdinalIgnoreCase)) {
        return "v$($Value.Substring(1))"
    }
    return "v$Value"
}

function Get-CliArtifact {
    param([Parameter(Mandatory = $true)][string]$Architecture)
    switch ($Architecture.ToUpperInvariant()) {
        "AMD64" { return "$Program-windows-x86_64.exe" }
        "X86_64" { return "$Program-windows-x86_64.exe" }
        "ARM64" { return "$Program-windows-aarch64.exe" }
        "AARCH64" { return "$Program-windows-aarch64.exe" }
        default { throw "Unsupported Windows CPU architecture: $Architecture" }
    }
}

function Get-CliArchitecture {
    $architecture = $env:PROCESSOR_ARCHITEW6432
    if ([string]::IsNullOrWhiteSpace($architecture)) {
        $architecture = $env:PROCESSOR_ARCHITECTURE
    }
    if ([string]::IsNullOrWhiteSpace($architecture)) {
        throw "Could not determine the Windows CPU architecture"
    }
    return $architecture
}

function Copy-CliDownload {
    param(
        [Parameter(Mandatory = $true)][string]$Url,
        [Parameter(Mandatory = $true)][string]$Destination
    )
    $uri = [Uri]$Url
    if ($uri.IsFile) {
        Copy-Item -LiteralPath $uri.LocalPath -Destination $Destination -Force
        return
    }
    if ($uri.Scheme -ne "https") {
        throw "Refusing non-HTTPS download URL: $Url"
    }
    [Net.ServicePointManager]::SecurityProtocol = (
        [Net.ServicePointManager]::SecurityProtocol -bor
        [Net.SecurityProtocolType]::Tls12
    )
    Invoke-WebRequest -Uri $uri -OutFile $Destination -UseBasicParsing
}

function Add-CliToUserPath {
    param([Parameter(Mandatory = $true)][string]$Directory)
    $userPath = [Environment]::GetEnvironmentVariable("Path", "User")
    $entries = @()
    if (-not [string]::IsNullOrWhiteSpace($userPath)) {
        $entries = $userPath.Split(";") | Where-Object { -not [string]::IsNullOrWhiteSpace($_) }
    }
    if ($entries | Where-Object { $_.TrimEnd("\") -ieq $Directory.TrimEnd("\") }) {
        return $false
    }
    [Environment]::SetEnvironmentVariable("Path", ((@($entries) + $Directory) -join ";"), "User")
    return $true
}

function Install-Cli {
    param(
        [string]$RequestedVersion,
        [string]$DestinationDirectory,
        [string]$RequestedRepository,
        [string]$RequestedReleaseBaseUrl,
        [switch]$SkipPathUpdate
    )
    if ([Environment]::OSVersion.Platform -ne [PlatformID]::Win32NT) {
        throw "install.ps1 supports Windows; use install.sh on Linux or macOS"
    }
    if ([string]::IsNullOrWhiteSpace($RequestedVersion)) {
        $RequestedVersion = Get-CliEnvironmentValue "VERSION"
        if ([string]::IsNullOrWhiteSpace($RequestedVersion)) { $RequestedVersion = "latest" }
    }
    if ([string]::IsNullOrWhiteSpace($RequestedRepository)) {
        $RequestedRepository = Get-CliEnvironmentValue "REPOSITORY"
        if ([string]::IsNullOrWhiteSpace($RequestedRepository)) {
            $RequestedRepository = $DefaultRepository
        }
    }
    if ([string]::IsNullOrWhiteSpace($RequestedReleaseBaseUrl)) {
        $RequestedReleaseBaseUrl = Get-CliEnvironmentValue "RELEASE_BASE_URL"
        if ([string]::IsNullOrWhiteSpace($RequestedReleaseBaseUrl)) {
            $RequestedReleaseBaseUrl = "https://github.com/$RequestedRepository/releases"
        }
        $RequestedReleaseBaseUrl = $RequestedReleaseBaseUrl.TrimEnd("/")
    }
    if ([string]::IsNullOrWhiteSpace($DestinationDirectory)) {
        $DestinationDirectory = Get-CliEnvironmentValue "INSTALL_DIR"
        if ([string]::IsNullOrWhiteSpace($DestinationDirectory)) {
            $DestinationDirectory = Join-Path $env:LOCALAPPDATA "Programs\$DisplayName\bin"
        }
    }

    $normalizedVersion = Get-CliNormalizedVersion $RequestedVersion
    $artifact = Get-CliArtifact (Get-CliArchitecture)
    $downloadBase = if ($normalizedVersion -eq "latest") {
        "$RequestedReleaseBaseUrl/latest/download"
    } else {
        "$RequestedReleaseBaseUrl/download/$normalizedVersion"
    }
    $temporary = Join-Path ([IO.Path]::GetTempPath()) "$Program-install-$([Guid]::NewGuid())"
    New-Item -ItemType Directory -Path $temporary | Out-Null
    try {
        $binaryPath = Join-Path $temporary $artifact
        $checksumPath = "$binaryPath.sha256"
        Write-Host "${Program}-install: downloading $artifact ($normalizedVersion)"
        Copy-CliDownload "$downloadBase/$artifact" $binaryPath
        Copy-CliDownload "$downloadBase/$artifact.sha256" $checksumPath

        $expected = (((Get-Content -LiteralPath $checksumPath -TotalCount 1).Trim()) -split "\s+")[0]
        if ($expected -notmatch "^[0-9A-Fa-f]{64}$") {
            throw "Release checksum file is malformed"
        }
        $actual = (Get-FileHash -LiteralPath $binaryPath -Algorithm SHA256).Hash
        if ($actual -ine $expected) { throw "SHA-256 checksum verification failed" }

        $reportedVersion = ((& $binaryPath --version) -join " ").Trim()
        if ($LASTEXITCODE -ne 0) { throw "Downloaded binary could not run on this machine" }
        if (-not $reportedVersion.StartsWith("$Program ", [StringComparison]::Ordinal)) {
            throw "Downloaded file did not identify itself as $DisplayName"
        }
        if ($normalizedVersion -ne "latest" -and $reportedVersion -ne "$Program $($normalizedVersion.Substring(1))") {
            throw "Downloaded binary version does not match requested release $normalizedVersion"
        }

        New-Item -ItemType Directory -Path $DestinationDirectory -Force | Out-Null
        $destination = Join-Path $DestinationDirectory "$Program.exe"
        $staging = Join-Path $DestinationDirectory ".$Program-install-$([Guid]::NewGuid()).exe"
        try {
            Copy-Item -LiteralPath $binaryPath -Destination $staging -Force
            if (Test-Path -LiteralPath $destination) {
                [IO.File]::Replace($staging, $destination, $null)
            } else {
                [IO.File]::Move($staging, $destination)
            }
        } finally {
            Remove-Item -LiteralPath $staging -Force -ErrorAction SilentlyContinue
        }
        $installedVersion = (& $destination --version) -join " "
        Write-Host "${Program}-install: installed $installedVersion to $destination"
        if (-not $SkipPathUpdate -and (Add-CliToUserPath $DestinationDirectory)) {
            Write-Host "${Program}-install: added $DestinationDirectory to your user PATH"
            Write-Host "${Program}-install: open a new terminal before running $Program"
        }
    } finally {
        Remove-Item -LiteralPath $temporary -Recurse -Force -ErrorAction SilentlyContinue
    }
}

if ((Get-CliEnvironmentValue "INSTALLER_SOURCE_ONLY") -ne "1" -and $env:RUST_CLI_RELEASE_INSTALLER_SOURCE_ONLY -ne "1") {
    Install-Cli `
        -RequestedVersion $Version `
        -DestinationDirectory $InstallDir `
        -RequestedRepository $Repository `
        -RequestedReleaseBaseUrl $ReleaseBaseUrl `
        -SkipPathUpdate:$NoModifyPath
}
